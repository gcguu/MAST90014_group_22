       " 'T_max_hours_alt1': 2.0,\n",
       " 'T_max_hours_alt2': 4.0,\n",
       " 'milk_spoilage_cost_per_hour': 0.15,\n",
       " 'loading_time_minutes': 15.0,\n",
       " 'service_time_minutes': 5.0}"
      ]
     },
     "execution_count": 5,
