   "metadata": {},
   "outputs": [],
   "source": [
    "# Imports\n",
    "import pandas as pd\n",
    "import gurobipy as gp\n",
    "from gurobipy import GRB"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "9e1eb8d9",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load data\n",
    "DATA_REAL = \"../data/real/\"\n",
    "DATA_SYN = \"../data/synthetic/\"\n",
    "\n",
    "distance_df = pd.read_csv(DATA_REAL + \"distance_matrix.csv\", index_col=0)\n",
    "time_df = pd.read_csv(DATA_REAL + \"time_matrix.csv\", index_col=0)\n",
    "\n",
    "cafes_df = pd.read_csv(DATA_SYN + \"cafes.csv\")\n",
    "demands_df = pd.read_csv(DATA_SYN + \"demands.csv\")\n",
    "products_df = pd.read_csv(DATA_SYN + \"products.csv\")\n",
    "vans_df = pd.read_csv(DATA_SYN + \"vans.csv\")\n",
    "depot_df = pd.read_csv(DATA_SYN + \"depot.csv\")\n",
    "perish_df = pd.read_csv(DATA_SYN + \"perishability_params.csv\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "366f59a5",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Sets\n",
    "depot_name = depot_df.loc[0, \"name\"]\n",
    "\n",
    "cafes = cafes_df[\"cafe_name\"].tolist()\n",
    "nodes = [depot_name] + cafes\n",
    "\n",
    "K = vans_df[\"van_id\"].tolist()\n",
    "P = products_df[\"product_id\"].tolist()\n",
    "\n",
    "milk_products = products_df.loc[\n",
    "    products_df[\"category\"] == \"milk\", \"product_id\"\n",
    "].tolist()\n",
    "\n",
    "A = [(i, j) for i in nodes for j in nodes if i != j]"
   ]
  },
  {
   "cell_type": "code",
<<<<<<< HEAD
